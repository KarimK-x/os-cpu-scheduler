/*QComboBox:hover {
    border-color: rgba(99, 179, 237, 1.0);
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
    //    stop:0 rgba(59, 130, 246, 0.35),
  //      stop:1 rgba(99, 102, 241, 0.35));
//}*/

QComboBox:focus {
    border: 2px solid rgba(79,139,255,0.45);
    background: rgba(255,255,255,0.05);/*qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 rgba(59, 130, 246, 0.3),
        stop:1 rgba(99, 102, 241, 0.3));*/
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 30px;
   border: 1px solid rgba(79,139,255,0.45);
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
    background: rgba(255,255,255,0.05);
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid rgba(99, 179, 237, 0.9);
    width: 0px;
    height: 0px;
}

QComboBox QAbstractItemView {
    color: white;
    background-color: #0f1b2d;
    border: 2px solid rgba(168,85,247,0.8);
    border-radius: 10px;
    padding: 6px;
    outline: none;
    selection-background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 rgba(59, 130, 246, 0.5),
        stop:1 rgba(99, 102, 241, 0.5));
    selection-color: white;
}

QComboBox QAbstractItemView::item {
    min-height: 60px;
    padding-top: 20px;
    padding-bottom: 20px;
    padding-left: 14px;
    border-radius: 6px;
}

QComboBox QAbstractItemView::item:hover {
    background: rgba(99, 179, 237, 0.2);
    color: #63b3ed;
}

QComboBox QAbstractItemView::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 rgba(59, 130, 246, 0.5),
        stop:1 rgba(99, 102, 241, 0.5));
    color: white;
}</string>
