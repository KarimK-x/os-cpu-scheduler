  <property name="styleSheet">
   <string notr="true">/* =====================================================
   MAIN WINDOW - PREMIUM MONOCHROME GRADIENT
   ===================================================== */
QMainWindow#MainWindow {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #0B0F20,
        stop:0.4 #121A33,
        stop:0.7 #0C1125,
        stop:1 #0B0F20
    );
    font-family: &quot;Segoe UI&quot;, sans-serif;
    color: #E0E7FF;
}

/* =====================================================
   CENTRAL WIDGETS
   ===================================================== */
QWidget#centralWidget_2,
QWidget#centralWidget {
    background: rgba(255,255,255,0.04);
    border-radius: 24px;
    border: 1px solid rgba(79,139,255,0.3);
}

/* =====================================================
   CARD FRAME
   ===================================================== */
QFrame#cardFrame {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 rgba(18,18,55,0.9),
        stop:1 rgba(38,38,95,0.9)
    );
    border-radius: 28px;
    border: 1px solid rgba(79,139,255,0.6);
}

/* =====================================================
   FUNCTION BUTTONS (TOP ROW) - VERY THIN/FLAT
   ===================================================== */
QPushButton#Compression,
QPushButton#Decompresssion,
QPushButton#Prettifying,
QPushButton#XMLconsistency,
QPushButton#Minifying,
QPushButton#XMLtoJSON {
    background: rgba(255,255,255,0.05);
    height: 35px;
    min-width: 100px;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: 600;
    color: #ffffff;
    border-radius: 20px;
    border: 2px solid rgba(139,92,246,0.5);
    box-shadow: 0 8px 35px rgba(139,92,246,0.6), 0 0 50px rgba(99,102,241,0.4);
}

QPushButton#Compression:hover,
QPushButton#Decompresssion:hover,
QPushButton#Prettifying:hover,
QPushButton#XMLconsistency:hover,
QPushButton#Minifying:hover,
QPushButton#XMLtoJSON:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #c084fc,
        stop:0.2 #a78bfa,
        stop:0.5 #818cf8,
        stop:0.8 #60a5fa,
        stop:1 #3b82f6
    );
    box-shadow: 0 20px 70px rgba(139,92,246,1), 0 0 100px rgba(99,102,241,0.8);
    border: 2px solid rgba(168,85,247,0.8);
}

QPushButton#Compression:pressed,
QPushButton#Decompresssion:pressed,
QPushButton#Prettifying:pressed,
QPushButton#XMLconsistency:pressed,
QPushButton#Minifying:pressed,
QPushButton#XMLtoJSON:pressed {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #a855f7,
        stop:0.2 #8b5cf6,
        stop:0.5 #6366f1,
        stop:0.8 #3b82f6,
        stop:1 #2563eb
    );
    box-shadow: 0 8px 35px rgba(139,92,246,0.7), 0 0 50px rgba(99,102,241,0.5);
}

/* =====================================================
   TEXT EDITOR - READ ONLY STYLE
   ===================================================== */
QTextEdit#textEdit {
    padding: 18px;
    font-size: 14px;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    color: #E0E7FF;
    background: rgba(255,255,255,0.06);
    border-radius: 18px;
    border: 1px solid rgba(79,139,255,0.45);
    box-shadow: inset 0 0 8px rgba(79,139,255,0.2);
}

QTextEdit#textEdit:hover {
    border: 1px solid #4F8BFF;
    box-shadow: 0 0 16px #4F8BFF, inset 0 0 8px rgba(79,139,255,0.25);
}

QTextEdit#textEdit:focus {
    border: 2px solid #2563EB;
    box-shadow: 0 0 25px #2563EB, inset 0 0 12px rgba(79,139,255,0.3);
}
/* =====================================================
   SIDE BUTTONS (save, new, new_2, graph) - 110px WIDTH
   ===================================================== */
QPushButton#graph,
QPushButton#save,
QPushButton#new,
QPushButton#new_2 {
    height: 40px;
    width: 110px;
    padding: 8px 12px;
    font-size: 14px;
    font-weight: 700;
    color: #E0E7FF;
    border-radius: 20px;
    border: none;
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #c084fc,
        stop:0.2 #a78bfa,
        stop:0.5 #818cf8,
        stop:0.8 #60a5fa,
        stop:1 #3b82f6
    );
    box-shadow: 0 8px 35px rgba(139,92,246,0.8), 0 0 50px rgba(99,102,241,0.5);
}

QPushButton#graph:hover,
QPushButton#save:hover,
QPushButton#new:hover,
QPushButton#new_2:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #a855f7,
        stop:0.2 #8b5cf6,
        stop:0.5 #6366f1,
        stop:0.8 #3b82f6,
        stop:1 #2563eb
    );
    box-shadow: 0 20px 70px rgba(139,92,246,1), 0 0 100px rgba(99,102,241,0.8);
    border: 2px solid rgba(168,85,247,0.8);
}

QPushButton#graph:pressed,
QPushButton#save:pressed,
QPushButton#new:pressed,
QPushButton#new_2:pressed {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #8b5cf6,
        stop:0.5 #6366f1,
        stop:1 #3b82f6
    );
    box-shadow: 0 8px 35px rgba(139,92,246,0.7), 0 0 50px rgba(99,102,241,0.5);
}
/* =====================================================
   SCROLL BARS (FOR TEXT EDITOR)
   ===================================================== */
QScrollBar:vertical {
    background: rgba(255,255,255,0.03);
    width: 12px;
    border-radius: 6px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: rgba(79,139,255,0.4);
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(79,139,255,0.6);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background: rgba(255,255,255,0.03);
    height: 12px;
    border-radius: 6px;
    margin: 0px;
}

QScrollBar::handle:horizontal {
    background: rgba(79,139,255,0.4);
    border-radius: 6px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background: rgba(79,139,255,0.6);
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}

/* =====================================================
   MENU BAR - PREMIUM STYLE WITH ROUNDED CORNERS
   ===================================================== */
QMenuBar {
    background: rgba(18,18,55,0.8);
    color: #E0E7FF;
    border-bottom: 1px solid rgba(79,139,255,0.3);
    padding: 5px;
    font-size: 14px;
    border-radius: 8px;
}

QMenuBar::item {
    background: transparent;
    padding: 8px 16px;
    border-radius: 12px;
    margin: 2px;
}

QMenuBar::item:selected {
    background: rgba(79,139,255,0.2);
    border: 1px solid rgba(79,139,255,0.4);
    border-radius: 12px;
}

QMenuBar::item:pressed {
    background: rgba(79,139,255,0.3);
    border-radius: 12px;
}

/* =====================================================
   MENU DROPDOWN - PREMIUM STYLE WITH ROUNDED CORNERS
   ===================================================== */
QMenu {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 rgba(18,18,55,0.95),
        stop:1 rgba(28,28,75,0.95)
    );
    color: #E0E7FF;
    border: 1px solid rgba(79,139,255,0.5);
    border-radius: 16px;
    padding: 8px;
}

QMenu::item {
    padding: 10px 30px 10px 20px;
    border-radius: 10px;
    margin: 2px;
}

QMenu::item:selected {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 rgba(139,92,246,0.3),
        stop:1 rgba(99,102,241,0.3)
    );
    border: 1px solid rgba(139,92,246,0.5);
    border-radius: 10px;
}

QMenu::separator {
    height: 1px;
    background: rgba(79,139,255,0.3);
    margin: 5px 10px;
    border-radius: 1px;
}</string>
