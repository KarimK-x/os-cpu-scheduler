             <item>
              <widget class="QPushButton" name="runButton">
               <property name="styleSheet">
                <string notr="true">/* Add your button objectNames below */
QPushButton#runButton,
QPushButton#resetButton,
QPushButton#saveButton {
background: rgba(255,255,255,0.05);
height: 25px;
min-width: 50px;
padding: 8px 20px;
font-size: 13px;
font-weight: 600;
color: #ffffff;
border-radius: 20px;
border: 2px solid rgba(139,92,246,0.5);
box-shadow: 0 8px 35px rgba(139,92,246,0.6), 0 0 50px rgba(99,102,241,0.4);
transition: all 0.35s ease;
}

QPushButton#runButton:hover,
QPushButton#resetButton:hover,
QPushButton#saveButton:hover {
background: qlineargradient(
    x1:0, y1:0, x2:1, y2:1,
    stop:0 #c084fc,
    stop:0.2 #a78bfa,
    stop:0.5 #818cf8,
    stop:0.8 #60a5fa,
    stop:1 #3b82f6
);
box-shadow: 0 20px 70px rgba(139,92,246,1), 0 0 100px rgba(99,102,241,0.8);
border: 2px solid rgba(168,85,247,0.8);
}

QPushButton#runButton:pressed,
QPushButton#resetButton:pressed,
QPushButton#saveButton:pressed {
background: qlineargradient(
    x1:0, y1:0, x2:1, y2:1,
    stop:0 #a855f7,
    stop:0.2 #8b5cf6,
    stop:0.5 #6366f1,
    stop:0.8 #3b82f6,
    stop:1 #2563eb
);
box-shadow: 0 8px 35px rgba(139,92,246,0.7), 0 0 50px rgba(99,102,241,0.5);
}</string>
               </property>
               <property name="text">
                <string>run</string>
               </property>
              </widget>
